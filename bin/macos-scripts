  local -a args=("$@")
  local arg

  for arg in "${args[@]}"; do
    case "$arg" in
      --verbose|-v|-h|--help|help)
        ;;
      *)
        usage_error "maintain installer list 不支持参数: $arg" print_maintain_installer_list_help
        return 1
        ;;
    esac
  done
}

